# Copy to .env for local testing. Never commit .env.

# From https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your phone number (only needed for auth.py locally, not set on Railway)
TELEGRAM_PHONE=

# String session from auth.py output — set this on Railway, never commit it
TELEGRAM_SESSION_STRING=

# Bot username to send phones to (with or without @)
TELEGRAM_LOOKUP_BOT_USERNAME=@YourDataBot

# Optional: lock down the service with a shared secret
# number-lookup must send X-API-Key: <this value> on every request
SERVICE_API_KEY=

# Default country code prepended to 10-digit numbers (digits only, default 91 = India)
DEFAULT_COUNTRY_CODE=91

# Minimum phones the bot accepts per batch (default 101)
BOT_MIN_PHONES=101

# Job timeout in seconds (default 1800 = 30 min)
JOB_TIMEOUT_SECONDS=1800
